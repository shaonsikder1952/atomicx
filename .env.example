# AtomicX — Causal Intelligence Engine
POSTGRES_PASSWORD=atomicx_dev
DATABASE_URL=postgresql+asyncpg://atomicx:atomicx_dev@localhost:5432/atomicx
DATABASE_URL_SYNC=postgresql://atomicx:atomicx_dev@localhost:5432/atomicx

REDIS_URL=redis://localhost:6379/0
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
QDRANT_URL=http://localhost:6333

# Exchange API (public endpoints — no key needed for market data)
BINANCE_WS_URL=wss://stream.binance.com:9443/ws

# Data Sources
COINGECKO_API_URL=https://api.coingecko.com/api/v3

# Logging
LOG_LEVEL=INFO

# Evolution System Controls
EVOLUTION_FREEZE=0              # Set to 1 to freeze all autonomous changes
ENABLE_CODE_EVOLUTION=0         # Set to 1 to enable self-modifying code (DANGEROUS - keep disabled)

# AWS Bedrock (Optional - for LLM-based code evolution)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0

# Cost Optimization
NEWS_SCAN_INTERVAL_MINUTES=5    # How often to scan news (higher = lower costs). Default: 5 minutes

# Monitoring (Optional)
SENTRY_DSN=                     # Error tracking
PROMETHEUS_PORT=9090            # Metrics export
